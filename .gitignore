# ==========================================
# PicaroIA - Master Gitignore
# ==========================================

# ------------------------------------------
# 1. SEGURIDAD (¡LO MÁS IMPORTANTE!)
# ------------------------------------------
# Bloquea archivos de configuración local y llaves de OpenAI/Azure/ElevenLabs
.env
.env.local
.env.*.local
*.pem
*.key

# ------------------------------------------
# 2. BACKEND (Node.js / TypeScript)
# ------------------------------------------
# Dependencias instaladas (pesan megabytes y se regeneran con npm install)
node_modules/
/backend/node_modules/

# Archivos de producción/compilación de TypeScript
/backend/dist/
/backend/build/

# Logs de error de npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Caché de herramientas de testing o TypeScript
.eslintcache
.parcel-cache

# ------------------------------------------
# 3. FIRMWARE (ESP32 / Arduino / PlatformIO)
# ------------------------------------------
# Si usas PlatformIO (Muy recomendado para ESP32)
.pio/
.piolibdeps/
.clang_complete
.gcc-flags.json

# Si usas Arduino IDE (Archivos temporales de compilación y binarios)
/firmware/**/build/
/firmware/**/bin/
*.bak
*.hex
*.bin

# ------------------------------------------
# 4. SISTEMA OPERATIVO Y EDITORES
# ------------------------------------------
# Archivos basura de macOS y Windows
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Configuración local de VS Code (opcional, pero recomendado ignorar configuraciones personales)
.vscode/launch.json
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
